// Copy this file to ./adapters/user.js (relative to where you run the
// service) to override the HTTP `USER_LOOKUP_URL` adapter with an in-process
// implementation. The JS file takes precedence over the env var.
//
// Required exports: resolveByPhone, resolveByUserId.
// Optional exports: listActiveUsers (only for broadcast triggers),
// isEligible (enables the eligibility gate).

// Replace these toy lookups with a query against your real datastore
// (Postgres, Firestore, Mongo, REST API, whatever).
const FAKE_DB = {
  byPhone: {
    '+15551111111': { userId: 'u_alice', channel: 'sms',      data: { tier: 'paid', name: 'Alice' } },
    '+15552222222': { userId: 'u_bob',   channel: 'whatsapp', data: { tier: 'free', name: 'Bob'   } }
  },
  byUserId: {
    u_alice: { phone: '+15551111111', channel: 'sms',      data: { tier: 'paid', name: 'Alice' } },
    u_bob:   { phone: '+15552222222', channel: 'whatsapp', data: { tier: 'free', name: 'Bob'   } }
  }
};

module.exports = {
  /**
   * Resolve an inbound Twilio phone number to a user.
   * @param {string} phone — E.164 (no `whatsapp:` prefix; the package strips it).
   * @returns {Promise<{ userId, phone, channel?, data? } | null>}
   */
  async resolveByPhone(phone) {
    const hit = FAKE_DB.byPhone[phone];
    if (!hit) return null;
    return { userId: hit.userId, phone, channel: hit.channel, data: hit.data };
  },

  /**
   * Resolve a userId (from a trigger payload) to a user.
   * @param {string} userId
   * @returns {Promise<{ userId, phone, channel?, data? } | null>}
   */
  async resolveByUserId(userId) {
    const hit = FAKE_DB.byUserId[userId];
    if (!hit) return null;
    return { userId, phone: hit.phone, channel: hit.channel, data: hit.data };
  },

  /**
   * (Optional) Page through active users for broadcast fan-out.
   * Required only if you POST triggers with userId='ALL'.
   * @param {{ limit, cursor? }} opts
   * @returns {Promise<{ users: string[], nextCursor: string | null }>}
   */
  async listActiveUsers({ limit }) {
    const all = Object.keys(FAKE_DB.byUserId);
    return { users: all.slice(0, limit), nextCursor: null };
  },

  /**
   * (Optional) Eligibility gate predicate. Activates the gate when present.
   * Return `true` to allow, `false` to block silently, or
   * `{ allowed: false, redirect: 'message text' }` to send a per-call
   * redirect overriding GATE_REDIRECT_MESSAGE.
   *
   * @param {{ userId: string, data: object | undefined }} input
   * @returns {Promise<boolean | { allowed: boolean, redirect?: string }>}
   */
  async isEligible({ userId, data }) {
    if (!data) return true;
    return data.tier === 'paid';
  }
};

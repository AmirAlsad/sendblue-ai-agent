# sendblue-ai-agent local configuration.
#
# Copy this file to .env and replace placeholders with real values.
# .env is gitignored. Do not commit Sendblue credentials, webhook secrets,
# ngrok tokens, phone numbers, or captured real message content.

# ---------------------------------------------------------------------------
# Agent server
# ---------------------------------------------------------------------------

# Optional. Local port for the Express agent server.
# Defaults to 3000 when omitted.
PORT=3000

# Optional. Set to 0 to suppress the autostart in src/index.ts (the server
# also stays off when NODE_ENV=test). Leave unset for normal `npm run dev`.
AGENT_AUTOSTART=1

# Required for normal `npm run dev` / `npm start`.
# Public base URL Sendblue can call. Used to build per-message status_callback
# URLs such as `${PUBLIC_BASE_URL}/webhook/status`.
# For repo-managed E2E, `dev:e2e` and `test:e2e` usually generate this from
# ngrok automatically, so E2E users can leave this as a placeholder.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# Required for normal `npm run dev` / `npm start`.
# HTTP endpoint this package calls to get AI/chat replies. The endpoint is
# provider-agnostic and should return the chat response contract documented by
# this repo. `dev:e2e` starts a deterministic local endpoint automatically.
CHAT_ENDPOINT_URL=http://localhost:4010/chat

# Optional. Timeout in milliseconds for calls to CHAT_ENDPOINT_URL.
# Defaults to 10000 when omitted.
CHAT_ENDPOINT_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Conversation intelligence
# ---------------------------------------------------------------------------

# Optional but recommended for production. Enables Redis-backed conversation
# state, inbound dedupe, outbound handle mappings, and BullMQ buffer timers.
# When omitted, the agent uses in-memory state suitable for local development
# and hardware-free tests only.
REDIS_URL=

# Optional. Redis TTL in seconds for conversation records and outbound handle
# mappings. Defaults to 86400.
CONVERSATION_TTL_SECONDS=86400

# Optional. TTL in seconds for inbound message_handle dedupe keys.
# Defaults to 86400.
DEDUPE_TTL_SECONDS=86400

# Optional. Buffering debounce settings for rapid multi-message bursts.
BUFFER_BASE_TIMEOUT_MS=2000
BUFFER_GROWTH_FACTOR=1.25
BUFFER_MAX_TIMEOUT_MS=8000
BUFFER_NOISE_MAX_DEVIATION=0.3
MAX_REPROCESS_ATTEMPTS=2
CANCELLED_MESSAGE_MAX_LENGTH=150
BUFFER_QUEUE_NAME=sendblue-buffer-timers

# Optional. Maximum time to wait for the current outbound status callback
# before advancing the ordered delivery queue. Defaults to 30000.
OUTBOUND_DELIVERY_TIMEOUT_MS=30000

# Optional. HTTP identity resolver. If set, the agent POSTs phone/conversation
# metadata and forwards `{ userId, data }` to the chat endpoint as `identity`.
USER_LOOKUP_URL=

# Optional. Timeout in milliseconds for the inline identity-resolver request
# before chat dispatch. Set to 0 to disable the abort (not recommended in
# production — a hung USER_LOOKUP_URL would stall buffering). Defaults to 5000.
IDENTITY_RESOLVER_TIMEOUT_MS=5000

# Optional. Booleans accept 1, true, yes, or on.
OUTBOUND_TYPING_INDICATORS_ENABLED=true
INBOUND_TYPING_STATE_ENABLED=true

# ---------------------------------------------------------------------------
# Rich Sendblue actions
# ---------------------------------------------------------------------------

# Optional. Parses supported XML-style tags from legacy string responses into
# the same ordered actions[] model. Defaults to true.
CHAT_RESPONSE_PARSE_TAGS=true
CHAT_RESPONSE_MESSAGE_TAG=message
CHAT_RESPONSE_NO_RESPONSE_TAG=no_response
CHAT_RESPONSE_REACTION_TAG=reaction
CHAT_RESPONSE_REPLY_TAG=reply

# Optional. Direct read receipts are opt-in, iMessage/RCS only, and fail open
# because Sendblue account enablement is required.
READ_RECEIPTS_ENABLED=false
READ_RECEIPT_DEBOUNCE_MS=250

# Optional. Typing indicators refresh while the chat request and ordered
# outbound queue are active, capped by TYPING_REFRESH_MAX_MS.
TYPING_REFRESH_INTERVAL_MS=5000
TYPING_REFRESH_MAX_MS=120000

# Optional. Group messages route only when addressed to this name or when a
# future payload references a known agent outbound message.
AGENT_DISPLAY_NAME=sb-agent

# Optional. When true (default), an inbound group message that contains a
# previously delivered agent message as a substring counts as addressing
# the agent. Set to false to require explicit @AGENT_DISPLAY_NAME mention or
# reply metadata only — avoids false-positive invocation on short prior
# replies (e.g. agent sent "yes" → user later writes "yes please").
GROUP_INVOCATION_CONTENT_FALLBACK=true

# Optional. When true, null identities or identities with authorized=false are
# acknowledged silently. In groups, only the invoking participant is checked.
VALID_USER_REQUIRED=false

# ---------------------------------------------------------------------------
# Sendblue API
# ---------------------------------------------------------------------------

# Required. Sendblue API credentials used for outbound send-message requests
# and repo-managed webhook registration.
SENDBLUE_API_KEY_ID=your-api-key-id
SENDBLUE_API_SECRET_KEY=your-api-secret-key

# Required. Dedicated Sendblue line this package sends from.
# E.164 only — leading "+" then 10-15 digits. loadConfig rejects malformed
# values (e.g. ++15551234567, missing +, dashes, spaces) at startup.
SENDBLUE_FROM_NUMBER=+15551234567

# Optional but recommended after real webhook capture.
# If set, incoming `/webhook/receive` and `/webhook/status` requests must send
# this value in SENDBLUE_WEBHOOK_SECRET_HEADER.
SENDBLUE_WEBHOOK_SECRET=replace-after-capturing-real-webhook

# Optional. Header name used for webhook secret validation.
# Defaults to sb-signing-secret, the header documented by Sendblue for webhook
# secrets. Captured real webhooks should still be kept as fixtures.
SENDBLUE_WEBHOOK_SECRET_HEADER=sb-signing-secret

# Optional. Sendblue API base URL.
# Defaults to https://api.sendblue.co when omitted.
SENDBLUE_API_BASE_URL=https://api.sendblue.co

# Optional. Sendblue v2/rich API base URL for group send, reactions, read
# receipts, and typing-rich endpoints. Defaults to https://api.sendblue.com.
SENDBLUE_API_V2_BASE_URL=https://api.sendblue.com

# ---------------------------------------------------------------------------
# Real-device E2E
# ---------------------------------------------------------------------------

# Optional. Local port used by `dev:e2e`, `test:e2e`, and `capture:fixtures`.
# Defaults to PORT, then 3000.
E2E_AGENT_PORT=3000

# Optional override. Leave blank for normal repo-managed E2E.
# If set, `test:e2e` uses this externally managed public URL instead of
# starting an ngrok SDK tunnel. `sendblue:webhooks` also uses this before
# PUBLIC_BASE_URL.
E2E_PUBLIC_BASE_URL=

# Required for `npm run test:e2e` and `npm run verify:e2e`.
# Phone number for the local iMessage-capable test device/account. This is kept
# explicit so test setup documents which real device is participating.
E2E_TEST_DEVICE_NUMBER=+15557654321

# Optional. Read-only Messages.app database path used to verify real replies.
# Defaults to ~/Library/Messages/chat.db. The terminal/test runner needs Full
# Disk Access to read this file.
E2E_MESSAGES_DB_PATH=~/Library/Messages/chat.db

# ---------------------------------------------------------------------------
# ngrok for repo-managed E2E
# ---------------------------------------------------------------------------

# Required for `npm run dev:e2e`.
# Required for `npm run test:e2e` unless E2E_PUBLIC_BASE_URL is set.
# Used by the @ngrok/ngrok SDK to start and stop the public tunnel automatically.
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Optional. Reserved stable ngrok domain. Leave blank to let ngrok generate a
# temporary URL; the repo will register that URL with Sendblue each run.
NGROK_DOMAIN=

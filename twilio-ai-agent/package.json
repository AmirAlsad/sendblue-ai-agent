{
  "name": "twilio-ai-agent",
  "version": "0.1.0",
  "description": "Twilio SMS/WhatsApp/RCS routing layer for AI chat agents — buffering, ordered delivery, typing indicators, reply context, status callbacks, and out-of-band triggers.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node src/index.js",
    "test:unit": "node tests/unit/run-all.js",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "keywords": [
    "twilio",
    "sms",
    "whatsapp",
    "rcs",
    "ai",
    "agent",
    "webhook",
    "router"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "node-fetch": "^2.7.0",
    "pino": "^9.6.0",
    "twilio": "^5.3.0",
    "uuid": "^9.0.1"
  }
}

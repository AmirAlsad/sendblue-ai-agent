# ============================================================
# twilio-ai-agent — environment configuration
# Copy to .env and fill in values. The runnable service reads
# these at startup; missing required keys cause a hard exit
# in production and a logged warning in development.
# ============================================================

# ----- Server -----

# Application environment. 'production' enforces Twilio signature validation
# and quiets debug logs; anything else (default 'development') keeps debug
# routes and signature validation off.
NODE_ENV=development

# HTTP server port. Twilio webhooks land here.
PORT=3001

# ----- Twilio (REQUIRED) -----

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio sender phone (E.164). Used as fallback "from" when Messaging Service
# SID isn't set.
TWILIO_PHONE_NUMBER=+1234567890

# Twilio Messaging Service SID. Recommended for outbound — enables RCS-first /
# SMS fallback / sender-pool delivery.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL Twilio POSTs delivery + read status to. REQUIRED for ordered
# delivery to work — without it, the queue can't advance past the first
# outbound message.
STATUS_CALLBACK_URL=https://your-domain.example.com/status/callback

# ----- Backend services (REQUIRED) -----

# Redis URL for state, queues, and BullMQ. Required for everything except
# naked smoke tests.
REDIS_URL=redis://localhost:6379

# Chat endpoint URL. Every inbound message and trigger is POSTed here. The
# response body (blocking JSON or streaming NDJSON) is sent back to the user.
# See examples/chat-endpoint-pseudocode.md for the request/response shape.
CHAT_ENDPOINT_URL=http://localhost:3000/chat

# ----- User resolution (pick one) -----

# HTTP user-lookup webhook. Used unless ./adapters/user.js is present (the JS
# file overrides). The package POSTs {resolveBy, value} and expects a user
# record back, or `null` for not-found. See examples/adapters/user.js.example
# for the alternative.
USER_LOOKUP_URL=http://localhost:3000/user-lookup

# Optional fallback message sent via Twilio when an inbound phone resolves to
# no user. If empty, unknown inbounds are silently ignored.
UNKNOWN_USER_MESSAGE=

# ----- Trigger ingestion (REQUIRED if you want out-of-band push) -----

# Bearer key for POST /triggers. Without this, the trigger endpoint returns 503.
TRIGGER_API_KEY=replace-with-a-strong-random-string

# ----- Optional: read receipts -----

# If your chat endpoint cares about read events (Twilio reports `read` status
# for RCS / WhatsApp / iMessage), set this URL. The package POSTs
# {userId, messageTimestamp, readAt, channel}. If unset, read receipts are
# logged at debug and dropped.
READ_RECEIPT_URL=

# ----- Optional: eligibility gate -----

# The gate is OFF by default. Activates when your user-adapter exports an
# isEligible function (or when GATE_ELIGIBILITY_URL is set below). Same
# Redis-backed rate-limited redirect mechanism either way.

# Per-user cooldown between redirect-to-app messages (seconds). Default 86400.
GATE_REDIRECT_TTL_SECONDS=86400

# Body of the redirect message sent to ineligible users. Channel-mirrored
# (SMS in → SMS out). Empty = silently block (no nudge sent).
GATE_REDIRECT_MESSAGE=

# Optional HTTP eligibility webhook. Used only when no isEligible() is
# exported by ./adapters/user.js. Package POSTs {userId, data} and expects
# {allowed: bool, redirect?: string} or a bare boolean.
GATE_ELIGIBILITY_URL=

# ----- Tunables: buffering -----

BUFFER_BASE_TIMEOUT_MS=2000
BUFFER_GROWTH_FACTOR=1.25
BUFFER_MAX_TIMEOUT_MS=8000
BUFFER_NOISE_MAX_DEVIATION=0.30
MAX_REPROCESS_ATTEMPTS=2
CANCELLED_MESSAGE_MAX_LENGTH=150
BUFFER_QUEUE_NAME=buffer-timers

# ----- Tunables: trigger queue -----

TRIGGER_QUEUE_TTL_DAYS=7
TRIGGER_MAX_RETRIES=2
TRIGGER_RETRY_DELAY_MS=5000
TRIGGER_POLL_INTERVAL_MS=1000
TRIGGER_LOCK_TTL_SECONDS=60
TRIGGER_MAX_CONCURRENT_USERS=10

# ----- Tunables: broadcast fan-out -----

BROADCAST_QUEUE_NAME=broadcast-distribution
BROADCAST_RATE_LIMIT=3

# ----- Tunables: user-lookup HTTP timeout -----

USER_LOOKUP_TIMEOUT_MS=5000

# sendblue-ai-agent local configuration.
#
# Copy this file to .env and replace placeholders with real values.
# .env is gitignored. Do not commit Sendblue credentials, webhook secrets,
# ngrok tokens, phone numbers, or captured real message content.

# ---------------------------------------------------------------------------
# Agent server
# ---------------------------------------------------------------------------

# Optional. Local port for the Express agent server.
# Defaults to 3000 when omitted.
PORT=3000

# Required for normal `npm run dev` / `npm start`.
# Public base URL Sendblue can call. Used to build per-message status_callback
# URLs such as `${PUBLIC_BASE_URL}/webhook/status`.
# For repo-managed E2E, `dev:e2e` and `test:e2e` usually generate this from
# ngrok automatically, so E2E users can leave this as a placeholder.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# Required for normal `npm run dev` / `npm start`.
# HTTP endpoint this package calls to get AI/chat replies. The endpoint is
# provider-agnostic and should return the chat response contract documented by
# this repo. `dev:e2e` starts a deterministic local endpoint automatically.
CHAT_ENDPOINT_URL=http://localhost:4010/chat

# Optional. Timeout in milliseconds for calls to CHAT_ENDPOINT_URL.
# Defaults to 10000 when omitted.
CHAT_ENDPOINT_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Sendblue API
# ---------------------------------------------------------------------------

# Required. Sendblue API credentials used for outbound send-message requests
# and repo-managed webhook registration.
SENDBLUE_API_KEY_ID=your-api-key-id
SENDBLUE_API_SECRET_KEY=your-api-secret-key

# Required. Dedicated Sendblue line this package sends from.
SENDBLUE_FROM_NUMBER=+15551234567

# Optional but recommended after real webhook capture.
# If set, incoming `/webhook/receive` and `/webhook/status` requests must send
# this value in SENDBLUE_WEBHOOK_SECRET_HEADER.
SENDBLUE_WEBHOOK_SECRET=replace-after-capturing-real-webhook

# Optional. Header name used for webhook secret validation.
# Defaults to sb-signing-secret, the header documented by Sendblue for webhook
# secrets. Captured real webhooks should still be kept as fixtures.
SENDBLUE_WEBHOOK_SECRET_HEADER=sb-signing-secret

# Optional. Sendblue API base URL.
# Defaults to https://api.sendblue.co when omitted.
SENDBLUE_API_BASE_URL=https://api.sendblue.co

# ---------------------------------------------------------------------------
# Real-device E2E
# ---------------------------------------------------------------------------

# Optional. Local port used by `dev:e2e`, `test:e2e`, and `capture:fixtures`.
# Defaults to PORT, then 3000.
E2E_AGENT_PORT=3000

# Optional override. Leave blank for normal repo-managed E2E.
# If set, `test:e2e` uses this externally managed public URL instead of
# starting an ngrok SDK tunnel. `sendblue:webhooks` also uses this before
# PUBLIC_BASE_URL.
E2E_PUBLIC_BASE_URL=

# Required for `npm run test:e2e` and `npm run verify:e2e`.
# Phone number for the local iMessage-capable test device/account. This is kept
# explicit so test setup documents which real device is participating.
E2E_TEST_DEVICE_NUMBER=+15557654321

# Optional. Read-only Messages.app database path used to verify real replies.
# Defaults to ~/Library/Messages/chat.db. The terminal/test runner needs Full
# Disk Access to read this file.
E2E_MESSAGES_DB_PATH=~/Library/Messages/chat.db

# ---------------------------------------------------------------------------
# ngrok for repo-managed E2E
# ---------------------------------------------------------------------------

# Required for `npm run dev:e2e`.
# Required for `npm run test:e2e` unless E2E_PUBLIC_BASE_URL is set.
# Used by the @ngrok/ngrok SDK to start and stop the public tunnel automatically.
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Optional. Reserved stable ngrok domain. Leave blank to let ngrok generate a
# temporary URL; the repo will register that URL with Sendblue each run.
NGROK_DOMAIN=

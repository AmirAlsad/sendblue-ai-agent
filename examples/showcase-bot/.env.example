# Required for any LLM call. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional. If set, lets you point config.yaml at openai:gpt-4o-mini etc.
OPENAI_API_KEY=

# Optional. Enables Groq Whisper transcription for inbound voice notes.
# Without it, audio messages get a placeholder text instead of a transcript.
GROQ_API_KEY=
